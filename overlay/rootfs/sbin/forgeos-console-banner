#!/bin/sh

PATH=/bin:/sbin:/usr/bin:/usr/sbin
export PATH

for tty in /dev/tty0 /dev/tty1 /dev/ttyS0 /dev/console; do
    [ -w "$tty" ] || continue
    {
        echo
        echo "ForgeOS boot complete: $(uname -r) on $(uname -m)"
        echo "Login prompts are available on tty1 and ttyS0."
        echo
    } > "$tty" 2>/dev/null || true
done
